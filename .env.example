# Copy this to .env for local dev (never commit the real .env).
# In Vercel: Project Settings -> Environment Variables, add these two,
# plus OPENROUTER_API_KEY (server-side only, no VITE_ prefix).

# Supabase Project Settings -> API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# NOTE: the anon key is DESIGNED to be public/client-side — Supabase security
# comes from Row Level Security policies (see supabase/schema.sql), not from
# hiding this key. This is different from the OpenRouter key, which must stay
# server-side only (see /api/chat.js).
